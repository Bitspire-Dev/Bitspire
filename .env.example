# Copy this file to .env and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ may be exposed to the browser.

# TinaCMS
# Set at least one client ID. The NEXT_PUBLIC_ variant is preferred.
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_CLIENT_ID=

# Required for Tina Cloud content access in production.
TINA_TOKEN=

# Optional. Set one of these if you want to override the default branch fallback
# (VERCEL_GIT_COMMIT_REF -> redesign).
NEXT_PUBLIC_TINA_BRANCH=
TINA_BRANCH=

# Optional. Usually generated automatically from client ID + branch.
NEXT_PUBLIC_TINA_CONTENT_API_URL=
TINA_CONTENT_API_URL=

# Optional local Tina GraphQL endpoint. Default: http://localhost:4001/graphql
TINA_LOCAL_API_URL=http://localhost:4001/graphql

# Optional. Set to true only if you intentionally use a public Tina content API
# and want to skip TINA_TOKEN in production.
TINA_ALLOW_PUBLIC_CONTENT_API=false

# Contact form / Resend
RESEND_API_KEY=
CONTACT_FROM="Your Brand <noreply@example.com>"
CONTACT_EMAIL=hello@example.com

# Rate limit / Upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=