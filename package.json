    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.35.1",
    "@vercel/speed-insights": "^1.3.1",
    "cookies-next": "^6.1.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.29.2",
    "next": "^16.1.0",
    "next-intl": "^4.6.1",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.3",
